<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.UnitItemController"
      spacing="20"
      alignment="CENTER_LEFT"
      style="-fx-padding: 15;"
      styleClass="item-card">

    <ImageView fx:id="icon" fitWidth="64" fitHeight="64"/>

    <VBox spacing="5">
        <Label fx:id="nameLabel" styleClass="item-label"/>
        <Label fx:id="statsLabel" styleClass="item-info"/>
        <Label fx:id="costLabel" styleClass="item-info"/>
    </VBox>

    <Button fx:id="actionButton"
            text="Crear"
            onAction="#onAction"
            styleClass="button"/>

</HBox>
