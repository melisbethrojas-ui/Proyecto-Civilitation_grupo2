<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.DesktopController"
            styleClass="root">

    <center>
        <VBox styleClass="page-container" spacing="30" alignment="TOP_CENTER">

            <!-- TOP BAR -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">
                <Label text="CIVILIZATIONS" styleClass="app-title"/>
            </HBox>

            <!-- HERO SECTION -->
            <VBox spacing="8" alignment="CENTER">
                <Label text="EL ALBA DE LA HISTORIA" styleClass="hero-title"/>
                <Label text="Escribe tu legado en piedra y sangre." styleClass="hero-subtitle"/>
            </VBox>

            <!-- MENÚ PRINCIPAL -->
            <VBox spacing="20"
                  alignment="CENTER"
                  styleClass="card"
                  style="-fx-padding: 40;">

                <Button text="Unidades"
                        onAction="#openUnits"
                        styleClass="menu-button"/>

                <Button text="Edificios"
                        onAction="#openBuildings"
                        styleClass="menu-button"/>

                <Button text="Batalla"
                        onAction="#openBattle"
                        styleClass="menu-button"/>

                <Button text="Estadísticas"
                        onAction="#openStats"
                        styleClass="menu-button"/>

                <Button text="Recursos"
                        onAction="#openResources"
                        styleClass="menu-button"/>

                <Button text="Defensas"
                        onAction="#openDefenses"
                        styleClass="menu-button"/>

                <Button text="Tecnologías"
                        onAction="#openTech"
                        styleClass="menu-button"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
