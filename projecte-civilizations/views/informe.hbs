<h2>Informe Detallat de Batalla #{{batalla.id}}</h2>

<div class="battle-card-detalle">
    <div class="battle-header {{batalla.resultado}}">
        <h3>Resultat final: ¡{{batalla.resultado}} contra {{batalla.enemigo}}!</h3>
        <span>Data del combat: {{batalla.fecha_batalla}}</span>
    </div>
    
    <div class="battle-body">
        <h3>Pèrdues i Residus Recuperats</h3>
        <p><strong>Residus de Fusta:</strong> {{batalla.residuos_madera}} | <strong>Residus de Ferro:</strong> {{batalla.residuos_hierro}}</p>
        
        <div class="losses-grid">
            <div class="losses-column">
                <h4>Les teves pèrdues (Civilització)</h4>
                <ul>
                    <li><strong>Menjar:</strong> {{batalla.coste_comida_perdido_civi}}</li>
                    <li><strong>Fusta:</strong> {{batalla.coste_madera_perdido_civi}}</li>
                    <li><strong>Ferro:</strong> {{batalla.coste_hierro_perdido_civi}}</li>
                </ul>
            </div>
            <div class="losses-column">
                <h4>Pèrdues de l'Enemic</h4>
                <ul>
                    <li><strong>Menjar:</strong> {{batalla.coste_comida_perdido_enem}}</li>
                    <li><strong>Fusta:</strong> {{batalla.coste_madera_perdido_enem}}</li>
                    <li><strong>Ferro:</strong> {{batalla.coste_hierro_perdido_enem}}</li>
                </ul>
            </div>
        </div>

        <hr>
        <h3>Desenvolupament del Combat Pas a Pas</h3>
        <pre class="log-desarrollo">{{batalla.desarrollo_paso_a_paso}}</pre>
    </div>
</div>

<p><a href="/batallas" class="btn-back">← Tornar al llistat de batalles</a></p>