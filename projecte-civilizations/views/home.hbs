<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projecte Civilizations - Panel de Control</title>
    <link rel="stylesheet" href="/css/styles.css">

<h1>Panel de Control de la Civilización</h1>

<div class="grid-container">
    <section class="card">
        <h2>Recursos Actuales</h2>
        <ul>
            <li><strong>Comida:</strong> {{civi.comida}}</li>
            <li><strong>Madera:</strong> {{civi.madera}}</li>
            <li><strong>Hierro:</strong> {{civi.hierro}}</li>
            <li><strong>Maná:</strong> {{civi.mana}}</li>
        </ul>
    </section>

    <section class="card">
        <h2>Tecnologías</h2>
        <ul>
            <li><strong>Ataque:</strong> Nivel {{civi.tech_ataque}}</li>
            <li><strong>Defensa:</strong> Nivel {{civi.tech_defensa}}</li>
        </ul>
    </section>

    <section class="card">
        <h2>Edificios Construidos</h2>
        <ul>
            <li><strong>Granjas:</strong> {{civi.granjas}}</li>
            <li><strong>Carpinterías:</strong> {{civi.carpinterias}}</li>
            <li><strong>Herrerías:</strong> {{civi.herrerias}}</li>
            <li><strong>Torres Mágicas:</strong> {{civi.torres_magicas}}</li>
            <li><strong>Iglesias:</strong> {{civi.iglesias}}</li>
        </ul>
    </section>
</div>

<h2>Estado del Ejército</h2>
<table class="data-table">
    <thead>
        <tr>
            <th>Tipo de Unidad</th>
            <th>Cantidad Disponible</th>
        </tr>
    </thead>
    <tbody>
        {{#each ejercito}}
        <tr>
            <td><strong>{{this.tipo_unidad}}</strong></td>
            <td>{{this.cantidad}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>