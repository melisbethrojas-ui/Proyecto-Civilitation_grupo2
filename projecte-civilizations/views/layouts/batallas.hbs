<h1>Historial de Reportes de Batalla</h1>

{{#if batallas.length}}
    {{#each batallas}}
    <div class="battle-card">
        <div class="battle-header {{this.resultado}}">
            <h3>Batalla #{{this.numero_batalla}} - ¡{{this.resultado}}!</h3>
            <span>{{this.fecha_batalla}}</span>
        </div>
        <div class="battle-body">
            <p><strong>Residuos Recuperados:</strong> Madera: {{this.residuos_madera}} | Hierro: {{this.residuos_hierro}}</p>
            <div class="losses-grid">
                <div>
                    <h4>Pérdidas Civilización</h4>
                    <ul>
                        <li>Comida: {{this.coste_comida_perdido_civi}}</li>
                        <li>Madera: {{this.coste_madera_perdido_civi}}</li>
                        <li>Hierro: {{this.coste_hierro_perdido_civi}}</li>
                    </ul>
                </div>
                <div>
                    <h4>Pérdidas Enemigo</h4>
                    <ul>
                        <li>Comida: {{this.coste_comida_perdido_enem}}</li>
                        <li>Madera: {{this.coste_madera_perdido_enem}}</li>
                        <li>Hierro: {{this.coste_hierro_perdido_enem}}</li>
                    </ul>
                </div>
            </div>
            <details>
                <summary>Ver desarrollo del combate paso a paso</summary>
                <pre class="log-desarrollo">{{this.desarrollo_paso_a_paso}}</pre>
            </details>
        </div>
    </div>
    {{/each}}
{{else}}
    <p>Aún no se han registrado batallas en el sistema.</p>
{{-- Fin del condicional --}}
{{/if}}