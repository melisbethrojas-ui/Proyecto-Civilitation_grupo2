<div class="hero-section" style="text-align: center; margin-bottom: 80px;">
    <h1 style="font-size: 3.5rem; margin-bottom: 10px;">L'Alba de la Història</h1>
    <p style="font-size: 1.2rem; color: var(--bronze); letter-spacing: 5px;">ESCRIU EL TEU LLEGAT EN PEDRA I SANG</p>
</div>

<div class="last-actions" style="margin-top: 50px;">
    <h2 style="text-align: center; margin-bottom: 30px;">Cròniques Recents del Front</h2>
    <div class="card" style="padding: 30px;">
        <table>
            <thead>
                <tr>
                    <th>ORDRE</th>
                    <th>ESTAT</th>
                    <th>DATA ESTEL·LAR</th>
                    <th>DETALLS</th>
                </tr>
            </thead>
            <tbody>
                {{#each ultimas}}
                <tr>
                    <td style="font-family: 'Cinzel'; color: var(--gold);">#{{this.numero_batalla}}</td>
                    <td><span class="badge {{this.resultado}}" style="padding: 5px 15px; border: 1px solid;">{{this.resultado}}</span></td>
                    <td style="font-size: 0.9rem; opacity: 0.7;">{{this.fecha_batalla}}</td>
                    <td><a href="/informe?informe={{this.numero_batalla}}" class="btn-detalles">ARXIU →</a></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>